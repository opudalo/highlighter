{
  "name": "highlighter",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "bootstrap:artifacts": "tsx pipeline/bootstrapArtifacts.ts",
    "backfill:story": "tsx pipeline/backfillStoryLayers.ts",
    "ingest": "tsx pipeline/ingest.ts",
    "validate:artifacts": "tsx pipeline/validateArtifacts.ts",
    "verify:dist": "tsx pipeline/verifyDist.ts",
    "build": "tsc -b && vite build && pnpm verify:dist",
    "typecheck": "tsc -b --pretty false",
    "test": "vitest run",
    "check": "pnpm typecheck && pnpm test && pnpm build"
  },
  "dependencies": {
    "@fontsource/dm-sans": "^5.2.6",
    "@fontsource/newsreader": "^5.2.6",
    "@xmldom/xmldom": "^0.9.10",
    "fflate": "^0.8.3",
    "idb": "^8.0.3",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/node": "^26.1.1",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "fake-indexeddb": "^6.2.5",
    "jsdom": "^25.0.1",
    "tsx": "^4.15.7",
    "typescript": "~5.6.2",
    "vite": "^5.4.21",
    "vitest": "^2.1.8"
  },
  "optionalDependencies": {
    "@rollup/rollup-darwin-x64": "4.62.2"
  },
  "packageManager": "pnpm@9.15.4"
}
